{
  "name": "samuelsena/simple-wp-mcp-adapter-oauth",
  "description": "Simple WP MCP Adapter OAuth plugin",
  "type": "wordpress-plugin",
  "authors": [
		{
			"name": "Samuel Sena",
			"homepage": "https://samuelsena.blog"
		}
	],
  "require-dev": {
		"squizlabs/php_codesniffer": "3.13.5",
		"wp-coding-standards/wpcs": "3.3.0",
		"dealerdirect/phpcodesniffer-composer-installer": "1.2.0"
	},
  "require": {
    "php": "^7.4 || ^8.0",
    "wordpress/abilities-api": "0.4.0",
    "wordpress/mcp-adapter": "0.4.1",
    "automattic/jetpack-autoloader": "5.0.16",
    "league/oauth2-server": "8.4.3",
    "guzzlehttp/psr7": "2.8.0"
  },
  "config": {
		"allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true,
      "automattic/jetpack-autoloader": true
    },
    "platform": {
      "php": "7.4.0"
    }
	}
}
